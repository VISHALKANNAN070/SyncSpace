# Server Environment Variables Schema
# Copy to .env.local and populate with real values

# Node environment ("development" or "production")
NODE_ENV=

# MongoDB connection string
MONGODB_URL=

# JWT secret for signing tokens
JWT_SECRET=

# GitHub OAuth credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth callback URL (must match GitHub app settings)
# Example: http://localhost:5000/auth/github/callback
CALLBACK_URL=

# Frontend URL (no trailing slash)
# Example: http://localhost:5173
FRONTEND_URL=
